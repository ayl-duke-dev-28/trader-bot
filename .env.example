# Copy this file to .env and fill in your Alpaca paper-trading keys.
# Get free paper keys at https://app.alpaca.markets/paper/dashboard/overview

ALPACA_API_KEY=your_paper_key_here
ALPACA_API_SECRET=your_paper_secret_here

# Optional: live keys. Only used if MODE=live in config.yaml.
ALPACA_LIVE_API_KEY=
ALPACA_LIVE_API_SECRET=
